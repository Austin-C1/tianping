{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@pmx/api-client": ["libs/api-client/src/index.ts"],
      "@pmx/contracts": ["libs/contracts/src/index.ts"],
      "@pmx/shared": ["packages/shared/src/index.ts"]
    }
  }
}
