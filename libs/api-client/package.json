{
  "name": "@pmx/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "npm run openapi:generate --workspace @pmx/api && openapi-typescript ../../apps/api/openapi.json -o src/generated/schema.ts",
    "test": "vitest run src"
  },
  "dependencies": {
    "openapi-fetch": "^0.15.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "typescript": "5.6.3",
    "vitest": "latest"
  }
}
