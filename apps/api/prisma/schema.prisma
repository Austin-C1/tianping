generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WalletType {
  EOA
  DEPOSIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PREVIEWED
  SIGNING_REQUESTED
  SIGNED
  SUBMITTING
  SUBMITTED
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCEL_REQUESTED
  CANCELLED
  REJECTED
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  role                 UserRole             @default(USER)
  passwordHash         String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  wallets              Wallet[]
  orders               Order[]
  trades               Trade[]
  positions            Position[]
  auditLogs            AuditLog[]
  liveTradingApprovalsApproved LiveTradingApproval[] @relation("LiveTradingApprovalApprovedBy")
  liveTradingApprovalsRevoked  LiveTradingApproval[] @relation("LiveTradingApprovalRevokedBy")
  syncJobRunsRequested SyncJobRun[] @relation("SyncJobRunRequestedBy")
  rateLimitEvents      RateLimitEvent[]
  walletChallenges     WalletChallenge[]
  depositWallets       DepositWallet[]
  walletOperations     WalletOperation[]
  relayerTransactions RelayerTransaction[]
}

model Wallet {
  id        String     @id @default(cuid())
  userId    String
  type      WalletType
  address   String
  chainId   Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, address, chainId])
  @@index([address])
}

model WalletChallenge {
  id         String    @id @default(cuid())
  userId     String
  nonce      String    @unique
  message    String
  address    String?
  chainId    Int?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model DepositWallet {
  id                        String               @id @default(cuid())
  userId                    String
  ownerAddress              String
  address                   String?
  chainId                   Int
  status                    String
  failureReason             String?
  pUsdBalance               Decimal?             @db.Decimal(18, 8)
  exchangeAllowance         Decimal?             @db.Decimal(18, 8)
  balanceAllowanceUpdatedAt DateTime?
  balanceAllowanceRaw       Json?
  raw                       Json?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  user                      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  operations                WalletOperation[]
  relayerTransactions       RelayerTransaction[]

  @@unique([userId, ownerAddress, chainId])
  @@index([address])
  @@index([userId, status])
}

model WalletOperation {
  id                   String               @id @default(cuid())
  userId               String
  depositWalletId      String?
  type                 String
  status               String
  failureReason        String?
  intentPayload        Json?
  signedPayload        Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositWallet        DepositWallet?       @relation(fields: [depositWalletId], references: [id], onDelete: SetNull)
  relayerTransactions RelayerTransaction[]

  @@index([userId, type, status])
  @@index([depositWalletId, updatedAt])
}

model RelayerTransaction {
  id                   String    @id @default(cuid())
  userId               String
  depositWalletId      String?
  walletOperationId    String?
  relayerTransactionId String?
  status               String
  failureReason        String?
  raw                  Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositWallet        DepositWallet? @relation(fields: [depositWalletId], references: [id], onDelete: SetNull)
  walletOperation      WalletOperation? @relation(fields: [walletOperationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([depositWalletId, updatedAt])
  @@index([walletOperationId, updatedAt])
  @@index([relayerTransactionId])
}

model MarketSnapshot {
  id          String   @id @default(cuid())
  marketId    String   @unique
  conditionId String?
  slug        String?
  question    String
  category    String?
  active      Boolean
  closed      Boolean
  enableOrderBook Boolean @default(false)
  clobTokenIds Json?
  outcomes    Json?
  outcomePrices Json?
  volume      Decimal? @db.Decimal(18, 8)
  volume24hr   Decimal? @db.Decimal(18, 8)
  liquidity   Decimal? @db.Decimal(18, 8)
  raw         Json
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  quotes      MarketQuoteSnapshot[]
  orders      Order[]
  trades      Trade[]
  positions   Position[]

  @@index([conditionId])
}

model MarketQuoteSnapshot {
  id               String         @id @default(cuid())
  marketSnapshotId String
  tokenId          String         @unique
  outcome          String
  outcomeIndex     Int
  bestBid          Decimal?       @db.Decimal(18, 8)
  bestAsk          Decimal?       @db.Decimal(18, 8)
  midpoint         Decimal?       @db.Decimal(18, 8)
  spread           Decimal?       @db.Decimal(18, 8)
  minOrderSize     Decimal?       @db.Decimal(18, 8)
  negRisk          Boolean        @default(false)
  tickSize         Decimal?       @db.Decimal(18, 8)
  orderBookHash    String?
  raw              Json?
  syncedAt         DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  marketSnapshot   MarketSnapshot @relation(fields: [marketSnapshotId], references: [id], onDelete: Cascade)

  @@index([marketSnapshotId, outcomeIndex])
  @@index([syncedAt])
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  marketSnapshotId String?
  clobOrderId     String?         @unique
  tokenId         String?
  outcome         String?
  side            OrderSide
  orderType       String?
  builderCode     String?
  funderAddress   String?
  signatureType   String?
  clobStatus      String?
  failureReason   String?
  status          OrderStatus     @default(PREVIEWED)
  price           Decimal         @db.Decimal(18, 8)
  size            Decimal         @db.Decimal(18, 8)
  rawPreview      Json?
  rawSignedOrder  Json?
  signedPayload   Json?
  submittedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketSnapshot  MarketSnapshot? @relation(fields: [marketSnapshotId], references: [id])
  trades          Trade[]

  @@index([userId, status])
  @@index([tokenId])
}

model Trade {
  id              String          @id @default(cuid())
  userId          String
  orderId         String?
  marketSnapshotId String?
  clobTradeId     String?         @unique
  side            OrderSide
  price           Decimal         @db.Decimal(18, 8)
  size            Decimal         @db.Decimal(18, 8)
  raw             Json?
  executedAt      DateTime
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order?          @relation(fields: [orderId], references: [id])
  marketSnapshot  MarketSnapshot? @relation(fields: [marketSnapshotId], references: [id])

  @@index([userId, executedAt])
}

model Position {
  id              String          @id @default(cuid())
  userId          String
  marketSnapshotId String?
  outcome         String
  size            Decimal         @db.Decimal(18, 8)
  averagePrice    Decimal         @db.Decimal(18, 8)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketSnapshot  MarketSnapshot? @relation(fields: [marketSnapshotId], references: [id])

  @@unique([userId, marketSnapshotId, outcome])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model LiveTradingApproval {
  id             String    @id @default(cuid())
  status         String
  approvalReason String
  approvedById   String?
  approvedAt     DateTime  @default(now())
  revokeReason   String?
  revokedById    String?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  approvedBy     User?     @relation("LiveTradingApprovalApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  revokedBy      User?     @relation("LiveTradingApprovalRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([status, approvedAt])
  @@index([approvedById, approvedAt])
  @@index([revokedById, revokedAt])
  @@index([revokedAt, approvedAt])
}

model SyncJobRun {
  id            String    @id @default(cuid())
  type          String
  status        String    @default("QUEUED")
  queueJobId    String?
  requestedById String?
  startedAt     DateTime?
  completedAt   DateTime?
  failureReason String?
  metadata      Json?
  result        Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  requestedBy   User?     @relation("SyncJobRunRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([type, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([queueJobId])
  @@index([status, updatedAt])
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  userId    String?
  key       String
  route     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([key, createdAt])
  @@index([userId, createdAt])
}
