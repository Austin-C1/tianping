{
  "name": "@pmx/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest --runInBand",
    "openapi:generate": "ts-node -r tsconfig-paths/register scripts/generate-openapi.ts",
    "prisma:generate": "node scripts/with-root-env.cjs prisma generate",
    "prisma:migrate": "node scripts/with-root-env.cjs prisma migrate dev",
    "db:seed": "node scripts/with-root-env.cjs ts-node prisma/seed.ts"
  },
  "nx": {
    "name": "api",
    "tags": ["type:app", "scope:api"],
    "targets": {
      "openapi": {
        "executor": "nx:run-commands",
        "outputs": ["{projectRoot}/openapi.json"],
        "options": {
          "command": "npm run openapi:generate --workspace @pmx/api"
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run start:dev --workspace @pmx/api"
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/bullmq": "latest",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/swagger": "^11.4.4",
    "@polymarket/builder-relayer-client": "^0.0.10",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@prisma/client": "6.19.3",
    "bullmq": "latest",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/testing": "latest",
    "@types/express": "latest",
    "@types/jest": "latest",
    "@types/node": "latest",
    "jest": "latest",
    "prisma": "6.19.3",
    "source-map-support": "latest",
    "ts-jest": "latest",
    "ts-loader": "latest",
    "ts-node": "latest",
    "tsconfig-paths": "latest",
    "typescript": "latest"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "testEnvironment": "node"
  }
}
