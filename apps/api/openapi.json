  "info": {
    "title": "PMX API",
    "description": "Polymarket trading platform API",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "service",
          "stage"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "USER"
            ]
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "AuthResultDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AdminSummaryDto": {
        "type": "object",
        "properties": {
          "registeredUsers": {
            "type": "number"
          },
          "adminUsers": {
            "type": "number"
          },
          "walletsConnected": {
            "type": "number"
          },
          "marketsSynced": {
            "type": "number"
          },
          "latestMarketSyncedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "marketQuotesSynced": {
            "type": "number"
          },
          "latestMarketQuoteSyncedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "ordersPreviewed": {
            "type": "number"
          },
          "openRiskEvents": {
            "type": "number"
          }
        },
        "required": [
          "registeredUsers",
          "adminUsers",
          "walletsConnected",
          "marketsSynced",
          "latestMarketSyncedAt",
          "marketQuotesSynced",
          "latestMarketQuoteSyncedAt",
          "ordersPreviewed",
          "openRiskEvents"
        ]
      },
      "AdminGateDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "READY",
              "PENDING",
              "BLOCKED"
            ]
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "details": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "key",
          "title",
          "owner",
          "status",
          "updatedAt"
        ]
      },
      "LiveApprovalReasonDto": {
        "type": "object",
        "properties": {}
      },
      "OrderRouterEnvironmentDto": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "preview",
              "paper",
              "live"
            ]
          },
          "clobHost": {
            "type": "string"
          },
          "chainId": {
            "type": "number",
            "nullable": true
          },
          "builderCodeConfigured": {
            "type": "boolean"
          },
          "relayerConfigured": {
            "type": "boolean"
          },
          "rpcConfigured": {
            "type": "boolean"
          },
          "liveTradingEnabled": {
            "type": "boolean"
          }
        },
        "required": [
          "mode",
          "clobHost",
          "chainId",
          "builderCodeConfigured",
          "relayerConfigured",
          "rpcConfigured",
          "liveTradingEnabled"
        ]
      },
      "ManagedUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "USER"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "walletCount": {
            "type": "number"
          },
          "walletStatus": {
            "type": "string",
            "enum": [
              "CONNECTED",
              "NOT_CONNECTED"
            ]
          },
          "primaryWalletAddress": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "createdAt",
          "walletCount",
          "walletStatus",
          "primaryWalletAddress"
        ]
      },
      "MarketQuoteItemDto": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "outcomeIndex": {
            "type": "number"
          },
          "tokenId": {
            "type": "string"
          },
          "bestBid": {
            "type": "string",
            "nullable": true
          },
          "bestAsk": {
            "type": "string",
            "nullable": true
          },
          "midpoint": {
            "type": "string",
            "nullable": true
          },
          "spread": {
            "type": "string",
            "nullable": true
          },
